<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.marcuschia.obsmcp-gateway</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__HOME__/bin/run-obs-gateway.sh</string>
    </array>

    <!-- Secrets and host config live HERE, never in the repo.
         Fill in real values when installing on the host. -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>OBS_VAULT</key>
        <string>__VAULT_PATH__</string>
        <key>OBS_SECRET_PATH</key>
        <string>__SECRET_PATH__</string>
        <key>OBS_BASE_URL</key>
        <string>__BASE_URL__</string>
        <key>ANTHROPIC_API_KEY</key>
        <string>__ANTHROPIC_API_KEY__</string>
        <key>OPENAI_API_KEY</key>
        <string>__OPENAI_API_KEY__</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>

    <key>WorkingDirectory</key>
    <string>/tmp</string>
    <key>StandardOutPath</key>
    <string>/tmp/obsmcp-gateway.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/obsmcp-gateway.log</string>
</dict>
</plist>
