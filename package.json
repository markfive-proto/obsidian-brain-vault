{
  "name": "obsidian-vault-cli",
  "version": "0.1.0",
  "description": "Community-built, open-source CLI for Obsidian vaults",
  "type": "module",
  "bin": {
    "obs": "./dist/index.js",
    "obs-mcp": "./dist/mcp/server.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/markfive-proto/obsidian-vault-cli.git"
  },
  "homepage": "https://github.com/markfive-proto/obsidian-vault-cli",
  "author": "markfive-proto",
  "keywords": [
    "obsidian",
    "cli",
    "markdown",
    "vault",
    "notes"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "date-fns": "^3.6.0",
    "fast-glob": "^3.3.2",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
